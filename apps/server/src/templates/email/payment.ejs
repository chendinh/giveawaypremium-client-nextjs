<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <style>
         *{
           font-size: 16px;
          color: #333333;
      }
      body {
        margin: 10px 0;
        font-family: Roboto, Arial, "sans-serif";
        background-color: black
      }
      .container {
        margin: 0 auto;
        max-width: 600px;
        background: #fff
      }
      .btn-confirm {
        background: linear-gradient(90deg, #EA5165 0%, #EF8E87 100%);
        border-radius: 30px;
        width: 100%;
        height: 50px;
        line-height: 50px;
        text-decoration: none;
        color: #fff !important;
        display: inline-block;
        text-align: center;
        margin: 0px;
      }
      .welcome {
        font-size: 22px;
        font-weight: bold;
        margin-bottom: 30px;
        text-align: center;
        padding-top: 50px;
      }
      .text-align-left {
          text-align: left
      }
      .content {
          text-align: left
      }
      .center {
        text-align: center;
      }
      p {
        margin: 10px;
        color: #333333;
        font-size: 16px;
        text-align: left;
      }
      .container {
        width: 550px;
        margin: 0px auto;
      }
      .code {
        background: #000;
        border-radius: 10px;
        padding: 10px 30px;
        color: #fff;
        font-weight: bold;
        display: inline-block;

      }
      .container div {
        padding-left: 20px;
        padding-right: 20px;
      }
      .footer{
        text-align: center;
        color: #828282;
        padding-top: 20px;
        padding-bottom: 20px;
      }
      @media only screen and (max-width: 600px) {
      .container {
        width: 100%;
        }
    }
    </style>
</head>
<body>
    <div class="center">
        <img src="https://i.ibb.co/72nXnBS/image-5.jpg" alt="logo" width="60px">
    </div>
    <div class="container">
        <p class="welcome">Xác nhận chuyển khoản</p>
        <div class="content">
            <p>Give Away Premium Quận 1 xác nhận đã chuyển khoản như sau:</p>
            <p> <%= 'Họ tên khách hàng: ' + customerName; %> </p>
            <p> <%= 'Số điện thoại: ' + phoneNumber; %> </p>
            <p> <%= 'CMND: ' + identityId; %> </p>
            <p> <%= 'Mã ký gửi: ' + consignmentId; %> </p>
            <p> <%= 'Số lượng: ' + numberOfProduct; %> </p>
            <p> <%= 'Ngân hàng đăng ký: ' + bankName; %> </p>
            <p> <%= 'ID Ngân hàng: ' + bankId; %> </p>
            <p> <%= 'Số tiền chuyển khoản: ' + moneyBack; %> </p>
        </div>

        <br/>
        <hr style=" border-top: 1px solid #f1f1f1; border-bottom: 0px; margin: 0px 10px"/>
        
        <div class="footer">
            <p>
                Lưu ý:
            </p>
            
            <p>
                Mọi vấn đề phát sinh, anh/chị vui lòng liên hệ Zalo 0703334443 để được hỗ trợ
            </p>
            
            <p>
            Xin cảm ơn anh/chị đã tin tưởng sử dụng dịch vụ tại Give Away Premium.
            </p>
            
            <p>
            Trân trọng,
            </p>
            <p>
            Give Away Premium
            </p>
        </div>
    </div>
</body>

</html>
