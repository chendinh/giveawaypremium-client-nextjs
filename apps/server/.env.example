# Copy this to .env and fill in your values
# Parse Server
APP_ID=myAppId
MASTER_KEY=myMasterKey
CLIENT_KEY=myClientKey
JAVAScript_KEY=myJavascriptKey
REST_API_KEY=myRestAPIKey
SERVER_URL=http://localhost:1337/parse

# Database (MongoDB example)
DATABASE_URI=mongodb://localhost:27017/giveawaypremium

# Parse Dashboard
PARSE_DASHBOARD_USERNAME=admin
PARSE_DASHBOARD_PASSWORD=your_secure_password
PARSE_DASHBOARD_COOKIE_SESSION_SECRET=myCookieSecret

# Cloud code path (default)
CLOUD=cloud/main.js

# Other services (optional)
PORT=1337
CLOUDINARY_NAME=demo
CLOUDINARY_API_KEY=demo_key
CLOUDINARY_API_SECRET=demo_secret

# Email (Gmail example)
MAIL_ADDRESS=your@gmail.com
MAIL_USER=your@gmail.com
MAIL_PASS=your_app_password
MAIL_SERVICE=gmail
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false

# GHTK
GHTK_TOKEN=your_ghtk_token
GHTK_URL=https://services.ghtk.vn

# Nhanh
NHANH_SERVER=https://dev.nhanh.vn
NHANH_VERSION=1.0
NHANH_SECRET_KEY=your_key
NHANH_API_USERNAME=your_username

# Schedule
ACTIVE_CAMPAIGN_SCHEDULE=0 * * * * *
