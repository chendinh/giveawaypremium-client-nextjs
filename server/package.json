    "url": "https://github.com/vinxenc/lime/issues"
  },
  "homepage": "https://github.com/vinxenc/lime#readme",
  "dependencies": {
    "app-root-path": "3.0.0",
    "axios": "1.3.4",
    "bluebird": "3.7.2",
    "cloudinary": "1.30.0",
    "cors": "2.8.5",
    "ejs": "3.1.8",
    "fastest-validator": "1.12.0",
    "form-data": "4.0.0",
    "helmet": "5.1.0",
    "md5": "2.3.0",
    "multer": "1.4.3",
    "node-fetch": "2.6.1",
    "node-schedule": "2.1.0",
