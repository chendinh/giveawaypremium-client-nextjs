    "@types/lodash": "4.14.182",
    "@types/md5": "2.3.1",
    "@types/multer": "1.4.7",
    "@types/node": "16.4.7",
    "@types/node-fetch": "2.5.12",
    "@types/node-schedule": "^1.3.2",
    "@types/nodemailer": "6.4.1",
    "@types/parse": "3.0.2",
