# ==============================================
# Next.js + Parse Server Environment Variables
# ==============================================

# --- Next.js Public Variables (Frontend) ---
# These will be available in the browser
NEXT_PUBLIC_APP_ID=myAppId
NEXT_PUBLIC_REST_API_KEY=myRestAPIKey
NEXT_PUBLIC_MASTER_KEY=myMasterKey
# Set to empty or remove to use local API proxy (/api/parse)
# NEXT_PUBLIC_SERVER_URL=

# --- Parse Server (Backend) ---
DATABASE_URI=mongodb://localhost:27017/giveawaypremium
APP_ID=myAppId
MASTER_KEY=myMasterKey
CLIENT_KEY=myClientKey
JAVASCRIPT_KEY=myJavascriptKey
REST_API_KEY=myRestAPIKey
# SERVER_URL is the internal Parse Server URL (auto-configured)
# PARSE_INTERNAL_PORT=4000

# --- Parse Dashboard ---
PARSE_DASHBOARD_USERNAME=administrator
PARSE_DASHBOARD_PASSWORD=
APP_NAME=GiveAwayPremium
# PARSE_DASHBOARD_TRUST_PROXY=1
# PARSE_DASHBOARD_ENCRYPTED=false
# PARSE_DASHBOARD_INSECURE_HTTP=true
# PARSE_DASHBOARD_COOKIE_SESSION_SECRET=myCookieSessionSecret

# --- Email (Nodemailer/SMTP) ---
MAIL_ADDRESS=giveawaypremiumquan1@gmail.com
MAIL_SERVICE=gmail
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=giveawaypremiumquan1@gmail.com
MAIL_PASS=

# --- Sendinblue (Brevo) ---
SENDINBLUE_API_KEY=

# --- Cloudinary ---
CLOUDINARY_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Nhanh.vn ---
NHANH_SERVER=https://dev.nhanh.vn
NHANH_VERSION=1.0
NHANH_SECRET_KEY=
NHANH_API_USERNAME=

# --- GHTK (Giao Hang Tiet Kiem) ---
GHTK_URL=https://services-staging.ghtklab.com
GHTK_TOKEN=

# --- Scheduled Jobs ---
# ACTIVE_CAMPAIN_SCHEDULE=0 * * * * *

# --- Other APIs ---
# NEXT_PUBLIC_API_URL=
