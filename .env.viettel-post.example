# Viettel Post Shipping Integration
# Copy this file to .env.local and fill in your credentials

# Viettel Post API Configuration
VIETTEL_POST_API_URL=https://partner.viettelpost.vn/v2
VIETTEL_POST_USERNAME=your_viettel_post_username
VIETTEL_POST_PASSWORD=your_viettel_post_password

# Note: Contact Viettel Post to get your API credentials:
# - Website: https://viettelpost.vn
# - Partner registration: https://partner.viettelpost.vn
# - Support: 1900 8095
