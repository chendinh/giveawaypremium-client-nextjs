{
  "name": "giveawaypremium",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=@giveawaypremium/web",
    "build:web": "npm run build --workspace=@giveawaypremium/web",
    "dev:server": "npm run start:dev --workspace=@giveawaypremium/server",
    "build:server": "npm run build --workspace=@giveawaypremium/server",
    "lint": "npm run lint --workspaces --if-present",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "npm run test --workspaces --if-present"
  },
  "devDependencies": {
    "prettier": "^3.3.3"
  }
}
